using BepInEx;
using UnityEngine;
using Photon.Pun;
using System.Collections.Generic;
using GorillaLocomotion;

[BepInPlugin("com.yourname.ultimatetool", "Ultra Hand-Menu Checker", "3.0.0")]
public class UltimateChecker : BaseUnityPlugin
{
    private bool showMenu = false;
    private bool safeMode = false;
    private Rect menuWindow = new Rect(0, 0, 450, 550);
    private Color currentThemeColor = new Color(0.1f, 0.1f, 0.1f, 0.95f);
    private Vector2 scrollPos;
    private Dictionary<int, string> suspiciousPlayers = new Dictionary<int, string>();

    // Hand tracking
    private bool isLeftHand = true;

    void Update()
    {
        // SAFE MODE: Press 'Esc' or a custom button to instantly hide everything
        if (Input.GetKeyDown(KeyCode.Escape)) { safeMode = !safeMode; showMenu = false; }
        if (safeMode) return;

        // TRIGGER DETECTION: Open menu on the hand that pressed the trigger
        if (ControllerInputPoller.instance.leftControllerIndexFloat > 0.5f) 
        { 
            showMenu = true; 
            isLeftHand = true; 
        }
        else if (ControllerInputPoller.instance.rightControllerIndexFloat > 0.5f) 
        { 
            showMenu = true; 
            isLeftHand = false; 
        }
        else 
        {
            showMenu = false; // Menu closes when trigger is released
        }

        if (showMenu && PhotonNetwork.InRoom) PerformLobbyScan();
    }

    void PerformLobbyScan()
    {
        foreach (VRRig rig in GorillaParent.instance.vrrigs)
        {
            if (rig.isMyPlayer) continue;
            float handDist = Vector3.Distance(rig.head.rigTarget.position, rig.rightHand.rigTarget.position);
            if (handDist > 1.7f && !suspiciousPlayers.ContainsKey(rig.creator.ActorNumber))
                suspiciousPlayers.Add(rig.creator.ActorNumber, "LONG ARMS");
        }
    }

    void OnGUI()
    {
        if (!showMenu || safeMode) return;

        // Position the menu based on which hand is holding the trigger
        float xPos = isLeftHand ? 50 : Screen.width - 500;
        menuWindow.x = xPos;
        menuWindow.y = Screen.height / 4;

        GUI.backgroundColor = currentThemeColor;
        menuWindow = GUI.Window(0, menuWindow, DrawMenuWindow, "MOD CHECKER: " + (isLeftHand ? "LEFT HAND" : "RIGHT HAND"));
    }

    void DrawMenuWindow(int windowID)
    {
        // --- THEME SELECTOR ---
        GUILayout.BeginHorizontal();
        if (GUILayout.Button("DARK")) currentThemeColor = new Color(0.1f, 0.1f, 0.1f, 0.95f);
        if (GUILayout.Button("NEON")) currentThemeColor = new Color(0f, 0.2f, 0.4f, 0.95f);
        GUILayout.EndHorizontal();

        // --- ENVIRONMENT ---
        GUILayout.Space(10);
        GUILayout.Label("WORLD SETTINGS");
        if (GUILayout.Button("DAY")) BetterDayNightManager.instance.SetTimeValues(1);
        if (GUILayout.Button("NIGHT")) BetterDayNightManager.instance.SetTimeValues(0);

        // --- MINI LEADERBOARD ---
        GUILayout.Space(20);
        GUILayout.Label("LOBBY MONITOR");
        scrollPos = GUILayout.BeginScrollView(scrollPos, GUILayout.Height(300));

        if (PhotonNetwork.InRoom)
        {
            foreach (var player in PhotonNetwork.PlayerList)
            {
                bool isSus = suspiciousPlayers.ContainsKey(player.ActorNumber);
                GUILayout.BeginHorizontal(GUI.skin.box);
                
                GUI.contentColor = isSus ? Color.red : Color.white;
                GUILayout.Label($"{player.NickName} {(isSus ? "[!]" : "")}", GUILayout.Width(180));
                
                if (GUILayout.Button("MUTE")) GorillaParent.instance.vrrigs[player.ActorNumber].SetMuted(true);
                if (GUILayout.Button("REPORT")) GorillaGameManager.instance.ReportPlayer(player.UserId, "Cheating", player.NickName);
                
                GUILayout.EndHorizontal();
                GUI.contentColor = Color.white;
            }
        }
        GUILayout.EndScrollView();
    }
}
